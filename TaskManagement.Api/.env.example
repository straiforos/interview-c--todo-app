# Backend Environment Variables Example
# Copy this file to .env.development and fill in the values

# Database Connection
ConnectionStrings__DefaultConnection=Host=db;Database=taskdb;Username=postgres;Password=postgres

# JWT Authentication
Jwt__Key=DevelopmentSecretKey_ChangeThisInProduction_MustBeLongEnough
Jwt__Issuer=TaskManagementApp
Jwt__Audience=TaskManagementApp
Jwt__ExpiryInMinutes=60
