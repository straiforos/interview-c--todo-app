meta {
  name: Create Task
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/tasks
  body: json
  auth: inherit
}

body:json {
  {
    "title": "Interview Take-home",
    "description": "Demonstrate DTO pattern and clean architecture"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("taskId", res.body.id);
  }
}
